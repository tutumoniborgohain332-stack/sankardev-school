{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/school-website build && pnpm --filter @workspace/api-server build",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "artifacts/api-server/dist/index.mjs": {
      "maxDuration": 30,
      "memory": 512,
      "includeFiles": "artifacts/school-website/dist/public/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/dist/index.mjs"
    }
  ]
}
