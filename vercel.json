{
  "version": 2,
  "buildCommand": "pnpm run build:vercel",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "artifacts/api-server/dist/index.mjs": {
      "runtime": "nodejs22.x",
      "maxDuration": 30,
      "memory": 512
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/dist/index.mjs"
    }
  ]
}
